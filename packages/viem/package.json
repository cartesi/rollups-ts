{
    "name": "@cartesi/viem",
    "description": "Cartesi viem extension",
    "version": "0.0.0",
    "dependencies": {
        "@apollo/client": "^3.11.4",
        "@cartesi/rpc": "workspace:*",
        "p-retry": "^6.2.1",
        "viem": "^2.23.6"
    },
    "devDependencies": {
        "@cartesi/rollups": "^2.0.0-rc.17",
        "@types/node": "^22.5.0",
        "@usecannon/cli": "^2.21.5",
        "@wagmi/cli": "^2.1.15",
        "npm-run-all": "^4.1.5",
        "ts-node": "^10.9.2",
        "tsup": "^8.2.4",
        "typescript": "^5.5.3",
        "vitest": "^3.1.1"
    },
    "peerDependencies": {
        "viem": "^2.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "run-s codegen compile",
        "codegen": "run-s codegen:cannon codegen:wagmi",
        "codegen:cannon": "cannon inspect cartesi-rollups:2.0.0-rc.17 --write-deployments ./deployment",
        "codegen:wagmi": "wagmi generate",
        "compile": "tsup",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
        "dev": "tsup --watch",
        "lint": "eslint",
        "prepack": "run-s build"
    }
}
